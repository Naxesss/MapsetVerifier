{
  "name": "mapsetverifier",
  "version": "2.0.0-beta.727",
  "description": "Mapset Verifier",
  "author": {
    "name": "Greaper",
    "url": "https://osu.ppy.sh/users/2369776"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Naxesss/MapsetVerifier.git"
  },
  "main": "electron-app/electron/main.cjs",
  "scripts": {
    "dev:all": "concurrently -k -n app,api -c cyan,yellow \"npm:dev\" \".\\\\src\\\\bin\\\\Debug\\\\net9.0\\\\MapsetVerifier.exe --urls=http://localhost:5005\"",
    "dev:frontend": "npm --prefix electron-app run dev",
    "dev:electron": "cross-env VITE_DEV_SERVER_URL=http://localhost:1420 electron .",
    "dev": "concurrently -k -n vite,electron -c cyan,magenta \"npm:dev:frontend\" \"wait-on http://localhost:1420 && npm run dev:electron\"",
    "build:frontend": "npm --prefix electron-app run build",
    "build": "npm run build:frontend",
    "build:backend": "dotnet build src/MapsetVerifier.csproj -c Debug",
    "dist": "npm run build && electron-builder --x64 -w",
    "dist-prerelease": "npm run build && electron-builder --x64 -w --config.win.icon=assets/icons/prerelease/icon.ico --config.mac.icon=assets/icons/prerelease/icon.icns --config.linux.icon=assets/icons/prerelease --config.nsis.installerIcon=assets/icons/prerelease/icon.ico --config.nsis.installerHeaderIcon=assets/icons/prerelease/icon.ico",
    "dist-all": "npm run build && electron-builder -wl",
    "dist-all-prerelease": "npm run build && electron-builder -wl --config.win.icon=assets/icons/prerelease/icon.ico --config.mac.icon=assets/icons/prerelease/icon.icns --config.linux.icon=assets/icons/prerelease --config.nsis.installerIcon=assets/icons/prerelease/icon.ico --config.nsis.installerHeaderIcon=assets/icons/prerelease/icon.ico",
    "release": "npm run build && electron-builder --publish always",
    "release-prerelease": "npm run build && electron-builder --publish always --config.win.icon=assets/icons/prerelease/icon.ico --config.mac.icon=assets/icons/prerelease/icon.icns --config.linux.icon=assets/icons/prerelease --config.nsis.installerIcon=assets/icons/prerelease/icon.ico --config.nsis.installerHeaderIcon=assets/icons/prerelease/icon.ico",
    "postinstall": "electron-builder install-app-deps",
    "prepare": "husky"
  },
  "devDependencies": {
    "concurrently": "9.1.0",
    "cross-env": "7.0.3",
    "electron": "41.2.1",
    "electron-builder": "26.15.6",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "wait-on": "8.0.1"
  },
  "dependencies": {
    "electron-updater": "6.8.3"
  },
  "overrides": {
    "rollup": "4.60.2"
  },
  "build": {
    "appId": "mapsetverifier",
    "productName": "Mapset Verifier",
    "asar": true,
    "files": [
      "electron-app/electron/**/*",
      "electron-app/dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "bin/server/dist",
        "to": "bin/server/dist"
      },
      {
        "from": "assets/icons",
        "to": "icons"
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "Naxesss",
        "repo": "MapsetVerifier"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icons/prod/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "category": "Utility",
      "icon": "assets/icons/prod",
      "executableName": "mapsetverifier",
      "desktop": {
        "StartupWMClass": "mapsetverifier"
      }
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icons/prod/icon.icns"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "runAfterFinish": true,
      "uninstallDisplayName": "${productName} Uninstaller.exe",
      "artifactName": "${productName} Installer.exe",
      "installerIcon": "assets/icons/prod/icon.ico",
      "installerHeaderIcon": "assets/icons/prod/icon.ico"
    }
  }
}
